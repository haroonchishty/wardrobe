# Replicate API token (for local development with wrangler dev)
REPLICATE_API_TOKEN=REPLACE_WITH_YOUR_TOKEN

# imgbb API key for image uploads
IMGBB_API_KEY=REPLACE_WITH_YOUR_IMGBB_KEY

# Note: Cloudflare Workers need these values configured as worker secrets too.
# Use `wrangler secret put REPLICATE_API_TOKEN` and `wrangler secret put IMGBB_API_KEY`.

# Frontend API URL (for production, point to your deployed Cloudflare Workers URL)
# Leave empty to use local development default (http://localhost:8787)
# VITE_API_URL=https://your-worker.your-subdomain.workers.dev
