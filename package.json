{
  "name": "wardrobe",
  "private": true,
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/haroonchishty/wardrobe.git"
  },
  "homepage": "https://haroonchishty.github.io/wardrobe",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "deploy:gh-pages": "GITHUB_PAGES=true npm run build && gh-pages -d dist",
    "deploy": "npm run worker:deploy"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "replicate": "^1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.1",
    "gh-pages": "^5.0.0",
    "vite": "^5.4.1",
    "wrangler": "^3.114.17"
  }
}
